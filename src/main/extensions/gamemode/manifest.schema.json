{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ackem:gamemode:manifest",
  "title": "Ackem GameProvider Manifest",
  "description": "游戏陪伴 Provider 的清单文件规范",
  "type": "object",
  "required": ["id", "name", "version", "category", "gameId", "gameName", "eventSources", "description", "author", "license", "main", "engineVersion"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+/[a-z0-9_-]+@\\d+\\.\\d+\\.\\d+$",
      "description": "唯一标识，格式：scope/name@version。如 ackem/mc-companion@1.0.0"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "显示名称"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "语义化版本号"
    },
    "category": {
      "type": "string",
      "const": "gamemode"
    },
    "gameId": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "游戏标识符，小写字母+数字+下划线"
    },
    "gameName": {
      "type": "string",
      "description": "游戏显示名，如 Minecraft、Genshin Impact"
    },
    "eventSources": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["log_file", "websocket", "process_stdout", "http_poll", "memory_scan", "manual"]
      },
      "minItems": 1,
      "description": "支持的事件源类型"
    },
    "description": { "type": "string", "maxLength": 256 },
    "author": { "type": "string" },
    "license": { "type": "string", "default": "AGPL-3.0" },
    "main": { "type": "string", "description": "入口文件相对路径" },
    "engineVersion": { "type": "string", "description": "最低引擎版本" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "homepage": { "type": "string", "format": "uri" },
    "recommendedPersonalityTags": { "type": "array", "items": { "type": "string" } },
    "icon": { "type": "string" }
  }
}
