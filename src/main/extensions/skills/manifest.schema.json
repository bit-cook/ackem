{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ackem:skills:manifest",
  "title": "Ackem Skill Manifest",
  "description": "技能 Skill 的清单文件规范",
  "type": "object",
  "required": ["id", "name", "version", "category", "skillType", "triggers", "permissions", "timeoutMs", "adultModeSafe", "description", "author", "license", "main", "engineVersion"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+/[a-z0-9_-]+@\\d+\\.\\d+\\.\\d+$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 64 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "category": { "type": "string", "const": "skill" },
    "skillType": {
      "type": "string",
      "enum": ["rule", "tool", "proactive", "workflow"],
      "description": "Skill 类型"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["manual", "keyword", "llm_function_call", "scheduled", "engine_event", "game_event", "system_event"]
      },
      "minItems": 1
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "触发关键词（triggers 包含 keyword 时必填）"
    },
    "functionDef": {
      "type": "object",
      "description": "LLM function calling 定义（triggers 包含 llm_function_call 时必填）",
      "required": ["name", "description", "parameters"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z_][a-z0-9_]*$" },
        "description": { "type": "string" },
        "parameters": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "object" },
            "properties": { "type": "object" },
            "required": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "permissions": { "type": "array", "items": { "type": "string" } },
    "timeoutMs": { "type": "number", "minimum": 1000, "maximum": 120000, "default": 30000 },
    "adultModeSafe": { "type": "boolean", "description": "成人模式下是否安全可用" },
    "conflicts": { "type": "array", "items": { "type": "string" } },
    "description": { "type": "string", "maxLength": 256 },
    "author": { "type": "string" },
    "license": { "type": "string", "default": "AGPL-3.0" },
    "main": { "type": "string" },
    "engineVersion": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "homepage": { "type": "string", "format": "uri" }
  }
}
